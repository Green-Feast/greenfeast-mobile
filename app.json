{
  "expo": {
    "name": "GreenFeast",
    "slug": "greenfeast-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "greenfeast",
    "userInterfaceStyle": "light",
    "ios": {
      "bundleIdentifier": "com.greenfeast.app",
      "supportsTablet": false
    },
    "android": {
      "package": "com.greenfeast.app",
      "adaptiveIcon": {
        "backgroundColor": "#1B5E20",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      }
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "color": "#1B5E20",
          "androidMode": "default",
          "androidCollapsedTitle": "GreenFeast"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1B5E20",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-image"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8f86ffc0-3e40-45c5-91af-e3fd32ea94b8"
      }
    }
  }
}
